# Required — get from https://tokenrouter.io (aggregator + recommender)
TOKENROUTER_API_KEY=tr_your_key_here

# Optional TokenRouter overrides (defaults: config.MODEL + anthropic provider)
# TOKENROUTER_MODEL=claude-opus-4-8
# TOKENROUTER_MODE=quality
# TOKENROUTER_PROVIDER=anthropic

# Optional — research agents fall back to mock evidence if these are absent
VIDEODB_API_KEY=
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=aiforge
