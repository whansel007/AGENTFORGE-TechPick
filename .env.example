# Required — TokenRouter API key from https://tokenrouter.com (not .io)
TOKENROUTER_API_KEY=your_key_here

# API host (default: https://api.tokenrouter.com)
# TOKENROUTER_BASE_URL=https://api.tokenrouter.com

# Model your key has access to (check dashboard or GET /v1/models)
# TOKENROUTER_MODEL=anthropic/claude-opus-4.8-fast

# Bright Data — patterns from brightdata/skills + ScrapeAlchemist hack-pack
BRIGHTDATA_API_KEY=
BRIGHTDATA_SERP_ZONE=aiforge          # SERP search (alias: BRIGHTDATA_ZONE)
# BRIGHTDATA_UNLOCKER_ZONE=           # optional: scrape top Reddit threads for richer quotes

# VideoDB — patterns from video-db/skills (alias: VIDEODB_API_KEY)
VIDEO_DB_API_KEY=
