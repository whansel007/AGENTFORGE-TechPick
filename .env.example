# Required — TokenRouter API key from https://tokenrouter.com (not .io)
TOKENROUTER_API_KEY=your_key_here

# API host (default: https://api.tokenrouter.com)
# TOKENROUTER_BASE_URL=https://api.tokenrouter.com

# Model your key has access to (check dashboard or GET /v1/models)
# TOKENROUTER_MODEL=anthropic/claude-opus-4.8-fast

# Optional — research agents fall back to mock evidence if these are absent
VIDEODB_API_KEY=
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=aiforge
